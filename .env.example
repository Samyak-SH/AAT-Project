# Copy this file to `.env` in the same directory as docker-compose.yml.
# `docker compose up` will automatically load it.

JWT_SECRET=please-change-me-in-production
DEMO_USER=admin
DEMO_PASS=admin

# ─── NLP options ─────────────────────────────────────────────────────────────
# Priority order used by /api/query:
#   1. Ollama     (local, private, free)
#   2. Anthropic  (remote, best quality)
#   3. Rule-based fallback (always available)
#
# Local Ollama (recommended). Install: https://ollama.com/download
#   brew install ollama && brew services start ollama
#   ollama pull llama3.2:1b     # ~1.3GB, fast on Apple Silicon
# Then leave these defaults:
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b
#
# Optional: set an Anthropic API key to prefer Claude when Ollama is down.
ANTHROPIC_API_KEY=
